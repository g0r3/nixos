+/*
+ * 'backendSNMPSupplyCount()' - Return the number of SNMP-reported supplies.
+ */
+
+int					/* O - Number of supplies, or 0 */
+backendSNMPSupplyCount(void)
+{
+  return (snmp_cached_count);
+}
+
+
+/*
+ * 'backendSNMPCachedLevels()' - Return the cached SNMP marker-levels string.
+ *
+ * Returns the comma-separated levels string from the last SNMP supply query,
+ * or NULL if no SNMP supplies have been reported.
+ */
+
+const char *				/* O - Levels string or NULL */
+backendSNMPCachedLevels(void)
+{
+  if (snmp_cached_levels[0])
+    return (snmp_cached_levels);
+  else
+    return (NULL);
+}
