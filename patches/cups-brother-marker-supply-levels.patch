diff --git a/backend/ipp.c b/backend/ipp.c
index 08a41ef..35fa3a7 100644
--- a/backend/ipp.c
+++ b/backend/ipp.c
@@ -3170,6 +3170,8 @@ report_attr(ipp_attribute_t *attr)	/* I - Attribute */
 
       case IPP_TAG_TEXT :
       case IPP_TAG_NAME :
+      case IPP_TAG_TEXTLANG :
+      case IPP_TAG_NAMELANG :
       case IPP_TAG_KEYWORD :
           quote_string(attr->values[i].string.text, valptr, (size_t)(value + sizeof(value) - valptr));
           valptr += strlen(valptr);
@@ -3316,25 +3318,90 @@ report_printer_state(ipp_t *ipp)	/* I - IPP response */
 
   if (ipp_supplies > 0)
   {
-    if ((marker = ippFindAttribute(ipp, "marker-colors", IPP_TAG_NAME)) != NULL)
-      report_attr(marker);
-    if ((marker = ippFindAttribute(ipp, "marker-high-levels",
-                                   IPP_TAG_INTEGER)) != NULL)
-      report_attr(marker);
-    if ((marker = ippFindAttribute(ipp, "marker-levels",
-                                   IPP_TAG_INTEGER)) != NULL)
-      report_attr(marker);
-    if ((marker = ippFindAttribute(ipp, "marker-low-levels",
-                                   IPP_TAG_INTEGER)) != NULL)
-      report_attr(marker);
-    if ((marker = ippFindAttribute(ipp, "marker-message",
-                                   IPP_TAG_TEXT)) != NULL)
-      report_attr(marker);
-    if ((marker = ippFindAttribute(ipp, "marker-names", IPP_TAG_NAME)) != NULL)
-      report_attr(marker);
-    if ((marker = ippFindAttribute(ipp, "marker-types",
-                                   IPP_TAG_KEYWORD)) != NULL)
-      report_attr(marker);
+    int		snmp_count;		/* SNMP supply count */
+    int		ipp_count;		/* IPP supply count */
+    const char	*snmp_levels;		/* Cached SNMP levels string */
+
+    snmp_count  = backendSNMPSupplyCount();
+    marker      = ippFindAttribute(ipp, "marker-levels", IPP_TAG_INTEGER);
+    ipp_count   = marker ? ippGetCount(marker) : 0;
+    snmp_levels = backendSNMPCachedLevels();
+
+    if (snmp_count > 0 && ipp_count > 0 && snmp_count > ipp_count &&
+        snmp_levels != NULL)
+    {
+     /*
+      * SNMP reported more supplies than IPP (e.g. drums, belt, waste toner).
+      * Merge: keep SNMP's complete supply list but update the first ipp_count
+      * levels with IPP's more precise percentages (SNMP often reports -3
+      * "some remaining" for toners, mapped to 50%).
+      */
+
+      int	snmp_vals[32];		/* Parsed SNMP levels */
+      int	j;			/* Looping var */
+      const char *sptr;			/* Pointer into SNMP levels string */
+      char	merged[32 * 4];		/* Merged levels string */
+      char	*mptr;			/* Pointer into merged string */
+
+      for (j = 0, sptr = snmp_levels; j < snmp_count && *sptr; j ++)
+      {
+        snmp_vals[j] = strtol(sptr, NULL, 10);
+        while (*sptr && *sptr != ',')
+          sptr ++;
+        if (*sptr == ',')
+          sptr ++;
+      }
+
+      for (j = 0; j < ipp_count && j < snmp_count; j ++)
+        snmp_vals[j] = ippGetInteger(marker, j);
+
+      for (j = 0, mptr = merged; j < snmp_count; j ++, mptr += strlen(mptr))
+      {
+        if (j)
+          *mptr++ = ',';
+        snprintf(mptr, sizeof(merged) - (size_t)(mptr - merged), "%d",
+                 snmp_vals[j]);
+      }
+
+      _cupsMutexLock(&report_mutex);
+      num_attr_cache = cupsAddOption("marker-levels", merged, num_attr_cache,
+                                     &attr_cache);
+      fprintf(stderr, "ATTR: marker-levels=%s\n", merged);
+      _cupsMutexUnlock(&report_mutex);
+
+     /*
+      * Skip marker-names, marker-types, marker-colors — keep SNMP's complete
+      * list which was already emitted by backendSNMPSupplies().
+      */
+
+      if ((marker = ippFindAttribute(ipp, "marker-message",
+                                     IPP_TAG_TEXT)) != NULL)
+        report_attr(marker);
+    }
+    else
+    {
+      if ((marker = ippFindAttribute(ipp, "marker-colors",
+                                     IPP_TAG_NAME)) != NULL)
+        report_attr(marker);
+      if ((marker = ippFindAttribute(ipp, "marker-high-levels",
+                                     IPP_TAG_INTEGER)) != NULL)
+        report_attr(marker);
+      if ((marker = ippFindAttribute(ipp, "marker-levels",
+                                     IPP_TAG_INTEGER)) != NULL)
+        report_attr(marker);
+      if ((marker = ippFindAttribute(ipp, "marker-low-levels",
+                                     IPP_TAG_INTEGER)) != NULL)
+        report_attr(marker);
+      if ((marker = ippFindAttribute(ipp, "marker-message",
+                                     IPP_TAG_TEXT)) != NULL)
+        report_attr(marker);
+      if ((marker = ippFindAttribute(ipp, "marker-names",
+                                     IPP_TAG_NAME)) != NULL)
+        report_attr(marker);
+      if ((marker = ippFindAttribute(ipp, "marker-types",
+                                     IPP_TAG_KEYWORD)) != NULL)
+        report_attr(marker);
+    }
   }
 }
 
